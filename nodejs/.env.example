# Gemini Web (cookies) — dùng src/bridges/gemini_cookies.json
# GEMINI_COOKIES=1

# Claude Web (cookies) — dùng src/bridges/claude_cookies.json
# CLAUDE_COOKIES=1

# Qwen Web (cookies) — dùng src/bridges/qwen_cookies.json
# QWEN_COOKIES=1

# OpenRouter
# OPENROUTER_API_KEY=your-key
# OPENROUTER_MODEL=openrouter/owl-alpha

# Gemini API
# GEMINI_API_KEY=your-key
# GEMINI_MODEL=gemini-2.0-flash-lite

# Ollama
# OLLAMA_MODEL=lfm2.5
# OLLAMA_BASE_URL=http://localhost:11434

# Anthropic-compatible API (unlimited.surf)
ANTHROPIC_BASE_URL=https://unlimited.surf
ANTHROPIC_API_KEY=your-unlimited-surf-api-key
ANTHROPIC_MODEL=claude-opus-4-7-20260101

# Unlimited.surf API (/api/chat - prompt-based tools)
# UNLIMITED_API_KEY=your-unlimited-surf-api-key
# UNLIMITED_MODEL=gateway-gpt-5
# UNLIMITED_BASE_URL=https://unlimited.surf

# Custom OpenAI-compatible API (KHÔNG dùng cho unlimited.surf — endpoint /v1/chat/completions trả 404)
# CUSTOM_API_BASE=http://...
# CUSTOM_API_KEY=your-key
# CUSTOM_MODEL=model-name

# Tự động chạy lệnh không cần xác nhận
# AUTO_EXEC=true
