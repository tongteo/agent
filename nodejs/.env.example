# OpenRouter API Configuration
OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Gemini API key (get free at https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.0-flash-lite

# Gemini Web (cookies) — set to any non-empty value to enable, uses ~/gemini/cookies.json
# GEMINI_COOKIES=1

# Claude Web (cookies) — set to any non-empty value to enable, uses ~/claude/cookies.json
# CLAUDE_COOKIES=1
