# OpenAI-compatible API (OmniRoute, OpenRouter, vLLM, etc.)
OPENAI_API_KEY=«redacted:sk-…»
OPENAI_BASE_URL=http://localhost:20128/v1    # OmniRoute local proxy
OPENAI_MODEL=oc/big-pickle                   # or gpt-4o, claude-sonnet-4, etc.

# ═══════════════════════════════════════════════
# Wolfram Alpha — calculator tool integration
# ═══════════════════════════════════════════════
# Get your free App ID at https://developer.wolframalpha.com/
# Calculator tool falls back to Wolfram Alpha when local eval cannot
# handle the expression (e.g. integrals, derivatives, symbolic math).
WOLFRAM_APP_ID=kat35v-krpg6j9gaw            # Wolfram Alpha App ID for calculator tool
