{
  "name": "openrouter-agent-cli",
  "version": "1.1.0",
  "description": "AI Agent CLI — terminal-based agent with tool integration, LSP support, and Playwright-based web providers (Gemini/Claude)",
  "main": "bin/openrouter",
  "bin": {
    "openrouter-cli": "./bin/openrouter"
  },
  "scripts": {
    "start": "node bin/openrouter",
    "test": "node --experimental-vm-modules tests/run.js",
    "test:watch": "node --experimental-vm-modules tests/run.js --watch",
    "lint": "node -e \"const fs=require('fs'),path=require('path');function walk(d){fs.readdirSync(d).forEach(f=>{const p=path.join(d,f);if(fs.statSync(p).isDirectory())walk(p);else if(p.endsWith('.js'))try{require('./'+p)}catch(e){console.log(p+':'+e.message)}})};walk('src');console.log('Lint OK')\"",
    "doctor": "node -e \"const deps=['puppeteer-core','chalk','cli-highlight','node-fetch','vscode-jsonrpc','vscode-languageserver-protocol','highlight.js'];deps.forEach(d=>{try{require(d);console.log('✓ '+d)}catch{console.log('✗ '+d+' (missing)')}});console.log('Node:',process.version)\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "claude-code-termux": "^1.0.119",
    "cli-highlight": "^2.1.11",
    "dotenv": "^17.3.1",
    "highlight.js": "^11.9.0",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.0.0",
    "puppeteer-core": "^24.0.0",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "terminal",
    "lsp",
    "playwright"
  ],
  "license": "MIT"
}
