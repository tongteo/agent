#!/usr/bin/env node
require('dotenv').config({ path: require('path').join(__dirname, '../.env'), quiet: true });
const { ChatBot } = require('../src/chat-bot');

async function main() {
    const args = process.argv.slice(2);
    const agentMode = !args.includes('--chat');
    const autoExecute = !args.includes('--no-auto-execute');

    // Parse --model, --base-url, --api-key CLI args (override env vars)
    const modelArg = args.find(a => a.startsWith('--model='));
    const baseUrlArg = args.find(a => a.startsWith('--base-url='));
    const apiKeyArg = args.find(a => a.startsWith('--api-key='));
    if (modelArg)     process.env.OPENAI_MODEL     = modelArg.split('=')[1];
    if (baseUrlArg)   process.env.OPENAI_BASE_URL  = baseUrlArg.split('=')[1];
    if (apiKeyArg)    process.env.OPENAI_API_KEY    = apiKeyArg.split('=')[1];

    const bot = new ChatBot('', '', agentMode, true, autoExecute);
    await bot.init();

    // Graceful shutdown: close LSP + reset terminal on SIGTERM/SIGINT
    const shutdown = async () => {
        process.stdout.write('\n');
        await bot.cleanup();
        process.exit(0);
    };
    process.on('SIGTERM', shutdown);
    process.on('SIGINT', shutdown);

    if (process.stdin.isTTY) {
        // Interactive mode
        await bot.chat();
    } else {
        // Non-interactive: read all piped input, process once, exit
        const chunks = [];
        for await (const chunk of process.stdin) {
            chunks.push(chunk);
        }
        const input = Buffer.concat(chunks).toString('utf-8').trim();
        if (input) {
            await bot.messageHandler.send(input);
            let full = '';
            await bot.messageHandler.stream((chunk) => { full += chunk; });
            if (full.trim()) {
                const { renderMarkdown } = require('../src/ui/formatter');
                process.stdout.write(renderMarkdown(full.trim()) + '\n');
            }
            if (bot.agentMode) {
                await bot.handleToolCalls();
            }
        }
        bot.prompt.close();
        process.exit(0);
    }
}

main().catch(e => {
    console.error('Fatal:', e.message);
    process.exit(1);
});
